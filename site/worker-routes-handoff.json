    "serviceDeliveryPlaybook": "https://gcagochina.com/service-delivery-playbook.json",
    "releaseGatesPage": "https://gcagochina.com/release-gates.html",
    "releaseGates": "https://gcagochina.com/release-gates.json"
  }
