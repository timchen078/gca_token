{
  "name": "gca-registration-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check src/worker.mjs",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "deploy:readiness": "python3 ../../tools/check_gca_worker_deploy_readiness.py --run-wrangler --run-cloudflare",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create gca_registration",
    "d1:migrate:local": "wrangler d1 migrations apply gca_registration --local",
    "d1:migrate:remote": "wrangler d1 migrations apply gca_registration --remote"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
